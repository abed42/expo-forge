{
	"expo": {
		"name": "expo-forge-demo",
		"slug": "expo-forge-demo",
		"version": "1.0.0",
		"orientation": "portrait",
		"scheme": "expoforge",
		"userInterfaceStyle": "automatic",
		"experiments": {
			"typedRoutes": true,
			"tsconfigPaths": true
		},
		"plugins": [
			"expo-router",
			"expo-system-ui",
			[
				"expo-build-properties",
				{
					"ios": {
						"deploymentTarget": "17.0"
					}
				}
			]
		],
		"ios": {
			"bundleIdentifier": "com.stephanos62.expo-forge-demo"
		}
	}
}
