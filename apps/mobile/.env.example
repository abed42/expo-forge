# =============================================================================
# apps/mobile/.env.example — THE only env file Expo loads for this app
# =============================================================================
# Copy to apps/mobile/.env.local and fill in values:
#   cp apps/mobile/.env.example apps/mobile/.env.local
#
# Why this path: Expo's project root is apps/mobile/ (where app.json lives).
# A repo-root .env.local is NOT read by Metro — keys there will look "set"
# in your editor and still be undefined at runtime.
#
# Rules:
# - Only EXPO_PUBLIC_* keys belong here (they are inlined into the client bundle).
# - Never put CLERK_SECRET_KEY, service-role keys, or webhook secrets here.
# - Never commit .env.local (gitignored). This .env.example stays empty of secrets.
# - After changing any EXPO_PUBLIC_* value, restart Metro (Fast Refresh will not
#   pick up new env inlines).
# =============================================================================

# Required — Clerk auth: dashboard.clerk.com -> API Keys (Publishable key)
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Required — Supabase: supabase.com/dashboard -> project -> Settings -> API Keys
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_KEY=

# Optional — analytics (inert until set)
# EXPO_PUBLIC_POSTHOG_KEY=
# EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Optional — crash reporting (inert until set)
# EXPO_PUBLIC_SENTRY_DSN=

# Optional — payments / RevenueCat (inert until set)
# Use the public SDK key: appl_… (iOS) or goog_… (Android). Not the secret key.
# EXPO_PUBLIC_REVENUECAT_API_KEY=
