{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"]
		},
		"typecheck": {
			"dependsOn": ["^typecheck"]
		},
		"lint": {},
		"test": {
			"dependsOn": ["//#test:scripts"]
		},
		"//#test:scripts": {},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
